Step 4: Time varying Analysis (by week)
# For each participant, split nodes into 3 ordered groups, compute network metrics per group.
period_metrics <- data.frame()

for (i in seq_along(pids)) {
  p <- pids[i]
  p_net <- participant_networks[[p]]
  nodes <- p_net$nodes
  cos_sim_all <- p_net$cos_sim
  n <- nrow(cos_sim_all)
  if (n < 6) next  # need at least 2 nodes per period
  
  # Split into thirds
  cut1 <- floor(n/3)
  cut2 <- floor(2*n/3)
  periods <- list(early = 1:cut1, middle = (cut1+1):cut2, late = (cut2+1):n)
  
  for (pname in names(periods)) {
    idx <- periods[[pname]]
    n_period <- length(idx)
    cos_sim_period <- cos_sim_all[idx, idx]
    # Traversal edges within period (only consecutive pairs in full sequence that both fall in this period)
    # We need consecutive indices in the full node order
    # Identify consecutive pairs where both nodes are in idx
    traversed_weights_period <- numeric(0)
    for (j in 1:(n-1)) {
      if (j %in% idx && (j+1) %in% idx) {
        traversed_weights_period <- c(traversed_weights_period, cos_sim_all[j, j+1])
      }
    }
    avg_edge_period <- if(length(traversed_weights_period) > 0) mean(traversed_weights_period) else NA
    
    # Build undirected graph for period
    max_w <- max(cos_sim_period)
    scaled_w <- cos_sim_period / max_w
    diag(scaled_w) <- 0
    g_period <- graph_from_adjacency_matrix(scaled_w, mode = "undirected", weighted = TRUE, diag = FALSE)
    
    # Compute metrics (using same functions as before, but careful about small graphs)
    # Clustering: skip if n_period < 3, else compute
    if (n_period >= 3) {
      # same C_i calculation as above, but using g_period
      W_p <- as_adjacency_matrix(g_period, attr = "weight", sparse = FALSE)
      k_p <- degree(g_period)
      C_i_p <- numeric(n_period)
      for (v in 1:n_period) {
        nb <- which(W_p[v,] > 0)
        if (length(nb) < 2) { C_i_p[v] <- 0; next }
        tri_sum <- 0
        for (j in nb) for (k in nb) if(j < k && W_p[j,k] > 0) tri_sum <- tri_sum + (W_p[v,j]*W_p[v,k]*W_p[j,k])^(1/3)
        C_i_p[v] <- (2 / (k_p[v]*(k_p[v]-1))) * tri_sum
      }
      avg_clust_period <- mean(C_i_p, na.rm = TRUE)
      
      # Path length
      D_p <- 1 - cos_sim_period
      diag(D_p) <- 0
      g_dist_p <- graph_from_adjacency_matrix(D_p, mode = "undirected", weighted = TRUE, diag = FALSE)
      sp_p <- distances(g_dist_p, algorithm = "dijkstra")
      sp_p[sp_p == Inf] <- NA
      char_path_period <- mean(sp_p[upper.tri(sp_p)], na.rm = TRUE)
      
      # Community detection (same consensus approach)
      # Only if n_period >= 5 or so
      if (n_period >= 5) {
        n_runs_p <- 50
        parts_p <- matrix(0, n_runs_p, n_period)
        Q_vec_p <- numeric(n_runs_p)
        for (run in 1:n_runs_p) {
          lc_p <- cluster_louvain(g_period, weights = E(g_period)$weight)
          parts_p[run,] <- membership(lc_p)
          Q_vec_p[run] <- modularity(lc_p)
        }
        # consensus selection (simplified: choose highest Q, or compute Rand z-score if needed)
        best_run_p <- which.max(Q_vec_p)
        Q_p <- Q_vec_p[best_run_p]
        n_comm_p <- length(unique(parts_p[best_run_p,]))
      } else {
        Q_p <- NA; n_comm_p <- NA
      }
      
    } else {
      avg_clust_period <- NA; char_path_period <- NA; Q_p <- NA; n_comm_p <- NA
    }
    
    period_metrics <- rbind(period_metrics, data.frame(
      pid = p, period = pname,
      avg_edge_weight = avg_edge_period,
      avg_clustering = avg_clust_period,
      char_path_length = char_path_period,
      modularity_Q = Q_p,
      n_communities = n_comm_p,
      n_nodes_period = n_period,
      stringsAsFactors = FALSE
    ))
  }
}

